DSS_DATABASE_URL=sqlite:///artifacts/backend-demo.db
DSS_MODEL_ARTIFACT_PATH=artifacts/logistic_regression.joblib
DSS_MODEL_METADATA_PATH=artifacts/model_metadata.json

# OpenAI-compatible LLM provider, for example MiMo v2.5.
LLM_PROVIDER_NAME=MiMo v2.5
LLM_API_KEY=your_mimo_api_key
LLM_BASE_URL=https://your-mimo-openai-compatible-base-url
LLM_MODEL=your-mimo-v2.5-model-name
LLM_TIMEOUT_SECONDS=30

# Legacy DeepSeek variables are still supported as fallback.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30
